generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl bypasses the connection pooler for Prisma migrations (required by Supabase pgbouncer)
  directUrl = env("DIRECT_URL")
}

enum CategoryGroup {
  COCHE
  FURGONETA_TRANSPORTE
  FURGONETA_CARGA
  TODOTERRENO
}

enum FuelType {
  GASOLINA
  DIESEL
  ELECTRICO
  HIBRIDO
}

enum TransmissionType {
  MANUAL
  AUTOMATICO
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ExtraType {
  BABY_SEAT
  SNOW_CHAINS
  ADDITIONAL_DRIVER
}

model Office {
  id           String        @id @default(cuid())
  slug         String        @unique
  city         String
  address      String
  phone        String
  email        String
  hours        String
  lat          Float
  lng          Float
  description  String
  vehicles     Vehicle[]
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("offices")
}

model Category {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  group         CategoryGroup
  description   String?
  order         Int           @default(0)
  price1Day     Decimal       @db.Decimal(10, 2)
  price2Day     Decimal       @db.Decimal(10, 2)
  price3Day     Decimal       @db.Decimal(10, 2)
  price4Day     Decimal       @db.Decimal(10, 2)
  price5Day     Decimal       @db.Decimal(10, 2)
  price6Day     Decimal       @db.Decimal(10, 2)
  price7Day     Decimal       @db.Decimal(10, 2)
  extraKmRate   Decimal       @db.Decimal(6, 3)
  deposit       Decimal       @db.Decimal(10, 2)
  franchise     Decimal       @db.Decimal(10, 2)
  powerMin      Int?
  powerMax      Int?
  seatsMin      Int?
  seatsMax      Int?
  // String[] used intentionally — Prisma doesn't support enum[] natively in schema DSL
  // Valid values: transmissions ∈ ['MANUAL','AUTOMATICO'], fuels ∈ ['GASOLINA','DIESEL','ELECTRICO','HIBRIDO']
  transmissions String[]
  fuels         String[]
  imageUrl      String?
  highlight     String?
  isActive      Boolean       @default(true)
  vehicles      Vehicle[]
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([group, order])
  @@index([isActive])
  @@map("categories")
}

model Vehicle {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  brand        String
  categoryId   String
  category     Category         @relation(fields: [categoryId], references: [id])
  seats        Int
  power        String
  fuel         FuelType
  transmission TransmissionType
  imageUrl     String
  highlight    String
  isActive     Boolean          @default(true)
  officeId     String
  office       Office           @relation(fields: [officeId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([officeId])
  @@index([categoryId])
  @@index([isActive])
  @@map("vehicles")
}

model Client {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String        @unique
  phone        String
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("clients")
}

model Reservation {
  id               String            @id @default(cuid())
  confirmationCode String            @unique
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id])
  officeId         String
  office           Office            @relation(fields: [officeId], references: [id])
  startDate        DateTime          @db.Date
  endDate          DateTime          @db.Date
  totalDays        Int
  estimatedKm      Int
  includedKm       Int
  extraKm          Int
  baseRate         Decimal           @db.Decimal(10, 2)
  extraKmCharge    Decimal           @db.Decimal(10, 2) @default(0)
  depositHeld      Decimal           @db.Decimal(10, 2)
  franchiseAmount  Decimal           @db.Decimal(10, 2)
  extrasTotal      Decimal           @db.Decimal(10, 2) @default(0)
  totalAmount      Decimal           @db.Decimal(10, 2)
  status           ReservationStatus @default(PENDING)
  notes            String?
  extras           ReservationExtra[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([categoryId, startDate, endDate])
  @@index([status])
  @@index([clientId])
  @@index([officeId])
  @@map("reservations")
}

model ReservationExtra {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          ExtraType
  quantity      Int         @default(1)
  pricePerDay   Decimal     @db.Decimal(10, 2)
  totalPrice    Decimal     @db.Decimal(10, 2)

  @@index([reservationId])
  @@map("reservation_extras")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}
